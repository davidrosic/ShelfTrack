# PostgreSQL Test Database Configuration
# These settings connect to the Docker test container
PGHOST=localhost
PGPORT=5433
PGUSER=test
PGPASSWORD=test
PGDATABASE=shelftrack_test

# Server Configuration
PORT=3001
FRONTEND_URL=http://localhost:5173

# JWT Secret (must be at least 32 characters)
# In production, use a cryptographically secure random string
JWT_SECRET=test-secret-minimum-32-characters-long-2025

# Environment
NODE_ENV=test

# Rate Limiting (disabled in tests for reliability)
ENABLE_RATE_LIMIT=false
